# Backend 環境變數;複製為 backend/.env 後依實際環境調整。
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/app
REDIS_URL=redis://localhost:6379/0
# JWT_SECRET 正式環境務必換成 64 bytes 隨機值,只從環境注入,NEVER 硬寫於原始碼
JWT_SECRET=change-me-64-bytes
ACCESS_TOKEN_TTL_MIN=20
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=false
# LLM 連線(T1.4)。model 名由 config/models.yaml 提供(§R R2;LLM_MODEL 已作廢,勿再設)。
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_TIMEOUT_S=120
CHAT_SYSTEM_PROMPT=你是一個誠實、精簡的中文助理。
CHAT_HISTORY_MAX_MESSAGES=20
